# Backend environment variables (used by serverless.yml via ${env:...})
# Copy to .env and fill in real values before `serverless deploy`.
# All resources should live in us-east-1 (see README).

# Cognito User Pool used by the API Gateway authorizer and the auth Lambdas
COGNITO_USER_POOL_ARN=arn:aws:cognito-idp:us-east-1:000000000000:userpool/us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Amazon Lex V2 bot (FlashAsk voice intent) — us-east-1
LEX_BOT_ID=PLACEHOLDER
LEX_BOT_ALIAS_ID=PLACEHOLDER

# Optional: override the Bedrock model (must be enabled in Bedrock model access)
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0
