{
  "compilerOptions": {
    "target":           "ES2020",
    "module":           "commonjs",
    "lib":              ["ES2020"],
    "outDir":           "./dist",
    "rootDir":          ".",
    "strict":           true,
    "noImplicitAny":    true,
    "strictNullChecks": true,
    "noUnusedLocals":   true,
    "noUnusedParameters": true,
    "esModuleInterop":  true,
    "resolveJsonModule": true,
    "skipLibCheck":     true
  },
  "include": ["functions/**/*", "shared/**/*", "seed/**/*"],
  "exclude": ["node_modules", "dist"]
}
